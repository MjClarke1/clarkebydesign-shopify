{% comment %}
  Thin trust-signal strip — 3 to 5 pill-style values shown right
  after the hero. Editable blocks so seasonal copy is easy to swap
  (e.g. "Free shipping over $75" during a promo).
{% endcomment %}

{{ 'section-trust-strip.css' | asset_url | stylesheet_tag }}

<section class="trust-strip">
  <div class="container trust-strip__inner">
    {%- for block in section.blocks -%}
      <div class="trust-item" {{ block.shopify_attributes }}>
        {%- if block.settings.show_check -%}
          <svg class="trust-item__check" width="14" height="14" viewBox="0 0 14 14" aria-hidden="true">
            <path d="M2 7.5 5.5 11 12 3.5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        {%- endif -%}
        <span class="trust-item__text">{{ block.settings.text }}</span>
      </div>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Trust Strip",
  "settings": [],
  "blocks": [
    {
      "type": "item",
      "name": "Item",
      "limit": 6,
      "settings": [
        { "type": "text",     "id": "text",       "label": "Text",            "default": "Handmade in Ontario" },
        { "type": "checkbox", "id": "show_check", "label": "Show check mark", "default": true }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Trust Strip",
      "blocks": [
        { "type": "item", "settings": { "text": "Handmade in Ontario" } },
        { "type": "item", "settings": { "text": "Personalized for you" } },
        { "type": "item", "settings": { "text": "Free local pickup" } },
        { "type": "item", "settings": { "text": "Ships Canada-wide" } }
      ]
    }
  ]
}
{% endschema %}
